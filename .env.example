# ==================== DJANGO SETTINGS ====================

# Django Secret Key (generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=your-secret-key-here

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma separated, e.g., localhost,127.0.0.1,yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== DATABASE ====================

# Database settings (default: SQLite)
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ==================== OPENAI API ====================

# OpenAI API Key (for question generation)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI Model (default: gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# ==================== EMAIL SETTINGS ====================

# Email backend (for password reset)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ==================== CORS SETTINGS ====================

# CORS allowed origins (for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==================== SECURITY ====================

# Password reset timeout (in seconds, default: 3600 = 1 hour)
PASSWORD_RESET_TIMEOUT=3600

# Session cookie age (in seconds, default: 1209600 = 2 weeks)
SESSION_COOKIE_AGE=1209600

# ==================== REDIS / CACHE ====================

# Redis URL (if using Redis for caching)
# REDIS_URL=redis://localhost:6379/0

# Cache timeout (in seconds)
CACHE_TIMEOUT=300
